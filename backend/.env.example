DATABASE_URL=postgresql+asyncpg://pmp:pmp123@localhost:5432/pmp_study
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-this-to-a-random-secret-key
UPLOAD_DIR=./uploads
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# ============================================
# LLM PROVIDER - Choose one:
#   ollama_local  -> Run Ollama on your machine
#   ollama_cloud  -> Use cloud Ollama (OpenRouter, Together, etc.)
#   claude        -> Use Anthropic Claude API
# ============================================
LLM_PROVIDER=ollama_local

# --- Ollama Local ---
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Ollama Cloud ---
# OLLAMA_CLOUD_URL=https://your-endpoint.com
# OLLAMA_CLOUD_KEY=your-key

# --- Claude API ---
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514
